import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.atomic.AtomicLong;

public class DNSCacheManager {
    
    // Custom Entry class to store IP and TTL metadata
    private static class DNSEntry {
        String ipAddress;
        long expiryTimestamp; // Absolute time in milliseconds

        DNSEntry(String ipAddress, long ttlSeconds) {
            this.ipAddress = ipAddress;
            this.expiryTimestamp = System.currentTimeMillis() + (ttlSeconds * 1000);
        }

        boolean isExpired() {
            return System.currentTimeMillis() > expiryTimestamp;
        }
    }

    private final int MAX_CAPACITY;
    private final Map<String, DNSEntry> cache;
    
    // Metrics tracking
    private final AtomicLong hits = new AtomicLong(0);
    private final AtomicLong misses = new AtomicLong(0);

    public DNSCacheManager(int capacity) {
        this.MAX_CAPACITY = capacity;
        // LinkedHashMap with accessOrder=true enables LRU eviction
        this.cache = Collections.synchronizedMap(new LinkedHashMap<String, DNSEntry>(capacity, 0.75f, true) {
            @Override
            protected boolean removeEldestEntry(Map.Entry<String, DNSEntry> eldest) {
                return size() > MAX_CAPACITY;
            }
        });
    }

    /**
     * Resolves domain to IP with TTL check and LRU management.
     */
    public String resolve(String domain) {
        long startTime = System.nanoTime();
        DNSEntry entry = cache.get(domain);

        // Case 1: Cache Hit and not expired
        if (entry != null && !entry.isExpired()) {
            hits.incrementAndGet();
            double duration = (System.nanoTime() - startTime) / 1_000_000.0;
            return String.format("Cache HIT -> %s (retrieved in %.2fms)", entry.ipAddress, duration);
        }

        // Case 2: Cache Miss or Expired
        misses.incrementAndGet();
        if (entry != null && entry.isExpired()) {
            cache.remove(domain); // Clean up expired entry
            System.out.print("Cache EXPIRED -> ");
        } else {
            System.out.print("Cache MISS -> ");
        }

        // Simulate Upstream Query (100ms latency)
        String ip = queryUpstreamDNS(domain);
        cache.put(domain, new DNSEntry(ip, 300)); // Default 300s TTL
        
        return String.format("Query upstream -> %s", ip);
    }

    private String queryUpstreamDNS(String domain) {
        // Mocking an upstream IP response
        return "172.217.14." + (new Random().nextInt(255));
    }

    public void getCacheStats() {
        long total = hits.get() + misses.get();
        double hitRate = (total == 0) ? 0 : (hits.get() / (double) total) * 100;
        System.out.printf("--- Stats --- %nHit Rate: %.1f%% | Hits: %d | Misses: %d%n", 
                          hitRate, hits.get(), misses.get());
    }

    public static void main(String[] args) throws InterruptedException {
        DNSCacheManager dns = new DNSCacheManager(100);

        System.out.println(dns.resolve("google.com"));
        System.out.println(dns.resolve("google.com")); // Should be a HIT
        
        // Example of capacity eviction
        for(int i = 0; i < 105; i++) {
            dns.resolve("site" + i + ".com");
        }
        
        dns.getCacheStats();
    }
}
