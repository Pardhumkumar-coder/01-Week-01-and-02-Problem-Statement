import java.util.*;

public class PlagiarismDetector {
    private static final int N_GRAM_SIZE = 5; // Using 5-grams for balance of accuracy/performance
    
    // Reverse Index: Maps an N-Gram hash to a list of Document IDs that contain it
    private final Map<Integer, Set<String>> ngramDatabase = new HashMap<>();
    // Stores the total n-gram count for each document to calculate similarity percentages
    private final Map<String, Integer> documentTotalNGrams = new HashMap<>();

    /**
     * Pre-processes and indexes a document into the system.
     */
    public void indexDocument(String docId, String content) {
        List<String> ngrams = generateNGrams(content);
        documentTotalNGrams.put(docId, ngrams.size());
        
        for (String ngram : ngrams) {
            int hash = ngram.hashCode(); // In production, use a more robust hash like Murmur3
            ngramDatabase.computeIfAbsent(hash, k -> new HashSet<>()).add(docId);
        }
    }

    /**
     * Analyzes a new document against the database.
     * Complexity: O(n) where n is the number of n-grams in the input document.
     */
    public void analyzeDocument(String newDocId, String content) {
        List<String> inputNGrams = generateNGrams(content);
        int totalInputNGrams = inputNGrams.size();
        
        // Map to track count of matches per existing document
        Map<String, Integer> matchCounts = new HashMap<>();

        for (String ngram : inputNGrams) {
            int hash = ngram.hashCode();
            if (ngramDatabase.containsKey(hash)) {
                for (String matchingDocId : ngramDatabase.get(hash)) {
                    matchCounts.put(matchingDocId, matchCounts.getOrDefault(matchingDocId, 0) + 1);
                }
            }
        }

        System.out.println("Analysis for: " + newDocId);
        System.out.println("-> Extracted " + totalInputNGrams + " n-grams");

        // Calculate and report similarity for documents with matches
        matchCounts.forEach((existingDocId, count) -> {
            double similarity = (count / (double) totalInputNGrams) * 100;
            String status = (similarity > 50) ? "PLAGIARISM DETECTED" : 
                            (similarity > 10) ? "suspicious" : "clean";
            
            System.out.printf("-> Found %d matching n-grams with \"%s\"%n", count, existingDocId);
            System.out.printf("   Similarity: %.1f%% (%s)%n", similarity, status);
        });
    }

    /**
     * Splits text into overlapping n-grams of N_GRAM_SIZE words.
     */
    private List<String> generateNGrams(String text) {
        String[] words = text.toLowerCase().replaceAll("[^a-zA-Z ]", "").split("\\s+");
        List<String> ngrams = new ArrayList<>();
        
        for (int i = 0; i <= words.length - N_GRAM_SIZE; i++) {
            StringBuilder sb = new StringBuilder();
            for (int j = 0; j < N_GRAM_SIZE; j++) {
                sb.append(words[i + j]).append(" ");
            }
            ngrams.add(sb.toString().trim());
        }
        return ngrams;
    }

    public static void main(String[] args) {
        PlagiarismDetector detector = new PlagiarismDetector();

        // Populate database
        detector.indexDocument("essay_089.txt", "The quick brown fox jumps over the lazy dog repeatedly");
        detector.indexDocument("essay_092.txt", "Data structures are essential for efficient software development and performance");

        // Analyze new submission
        String submission = "Data structures are essential for efficient software engineering and system performance";
        detector.analyzeDocument("student_submission.txt", submission);
    }
}
